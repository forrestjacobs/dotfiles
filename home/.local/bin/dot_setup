#!/usr/bin/env bash
set -euo pipefail

function check_all() {
  for script_path in "${HOME}"/.local/share/dotfiles/setup/*.sh; do
    script_name=$(basename -- "$script_path" .sh)
    if ! dot_setup check "${script_name}"; then
      echo "Call 'dot_setup ${script_name}' to set up $(dot_setup describe "${script_name}")"
    fi
  done
}

case "${1:-}" in
  "")
    check_all
    ;;

  describe)
    . "${HOME}/.local/share/dotfiles/setup/${2}.sh"
    describe
    ;;

  check)
    . "${HOME}/.local/share/dotfiles/setup/${2}.sh"
    check > /dev/null
    ;;

  *)
    . "${HOME}/.local/share/dotfiles/setup/${1}.sh"
    if ! check > /dev/null; then
      read -p "Set up $(describe)? " -n 1 -r
      echo
      if [[ $REPLY =~ ^[Yy]$ ]]; then
        fix
        check_all
      fi
    fi
    ;;
esac
