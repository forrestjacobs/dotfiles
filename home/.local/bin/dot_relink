#!/usr/bin/env bash
set -e

pushd "$(dirname "$(realpath "${BASH_SOURCE:0}")")" > /dev/null
dotfile_home="$(git rev-parse --show-toplevel)/home"
popd > /dev/null

function clean_links() {
  if [ -d "${1}" ]; then
    find "${1}" -type l -exec sh -c '
      for x; do
        [ -e "$x" ] || rm "$x"
      done
    ' _ {} +
  fi
}

clean_links "${HOME}/.config"
clean_links "${HOME}/.local/bin"
clean_links "${HOME}/.local/share"

find "${dotfile_home}" \( -type f -or -type l \) '!' -name .DS_Store -exec bash -c '
  symlink="$1${3#$2}"
  target="${3}"
  if [ -f "$symlink" ] && { [ ! -L "$symlink" ] || [ "$(readlink "$symlink")" != "$target" ]; }; then
    readlink "$symlink"
    echo "Moving $symlink to $symlink.old"
    mv "$symlink" "$symlink.old"
  fi
  if [ ! -f "$symlink" ]; then
    echo mkdir -p "$(dirname "$symlink")"
    echo ln -s "$target" "$symlink"
  fi
' find-bash "${HOME}" "${dotfile_home}" {} ';'
