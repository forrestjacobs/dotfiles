#!/usr/bin/env bash
set -e

if [ -L "$1" ]; then
  >&2 echo "'$1' is a symlink"
  exit 1
fi

file="$(realpath "$1")"
if [[ $file != "${HOME}/"* ]]; then
  >&2 echo "'$1' is not in your home directory"
  exit 2
fi

if [[ $file == "${HOME}/.cache/"* ]]; then
  >&2 echo "'$1' is already in cache"
  exit 3
fi
file="${file#"${HOME}"/}"
dashed_file="${file//\//-}"

mkdir -p "${HOME}/.cache/adopted"
mv "${HOME}/${file}" "${HOME}/.cache/adopted/${dashed_file}"
ln -s "${HOME}/.cache/adopted/${dashed_file}" "${HOME}/${file}"
