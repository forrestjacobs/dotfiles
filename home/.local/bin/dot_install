#!/usr/bin/env bash
set -euo pipefail

IFS=':' read -ra dotfiles_paths <<< "$("$(dirname "${BASH_SOURCE:0}")/dot_path")"

function describe() {
  (
    set -euo pipefail
    . "${HOME}/.local/share/dotfiles/setup/${1}.sh"
    describe
  )
}

function check() {
  (
    set -euo pipefail
    . "${HOME}/.local/share/dotfiles/setup/${1}.sh"
    check > /dev/null
  )
}

function fix() {
  (
    set -euo pipefail
    . "${HOME}/.local/share/dotfiles/setup/${1}.sh"
    fix
  )
}

function check_all() {
  echo "Checking optional setup"
  for script_path in "${HOME}"/.local/share/dotfiles/setup/*.sh; do
    script_name=$(basename -- "$script_path" .sh)
    if ! check "${script_name}"; then
      echo "Call 'dot_install ${script_name}' to set up $(describe "${script_name}")"
    fi
  done
}

function clean_links() {
  if [ -d "${1}" ]; then
    find "${1}" -type l -exec sh -c '
      for x; do
        [ -e "$x" ] || rm "$x"
      done
    ' _ {} +
  fi
}

function link_config() {
  echo 'Linking config files'

  clean_links "${HOME}/.config"
  clean_links "${HOME}/.local/bin"
  clean_links "${HOME}/.local/share"

  for dotfiles_path in "${dotfiles_paths[@]}"; do
    find "${dotfiles_path}/home" \( -type f -or -type l \) '!' -name .DS_Store -exec bash -c '
      symlink="$1${3#$2}"
      target="${3}"
      if [ -f "$symlink" ] && { [ ! -L "$symlink" ] || [ "$(readlink "$symlink")" != "$target" ]; }; then
        readlink "$symlink"
        echo "Moving $symlink to $symlink.old"
        mv "$symlink" "$symlink.old"
      fi
      if [ ! -f "$symlink" ]; then
        mkdir -p "$(dirname "$symlink")"
        ln -s "$target" "$symlink"
      fi
    ' find-bash "${HOME}" "${dotfiles_path}/home" {} ';'

    eval "$(shell=bash "${HOME}/.config/dotfiles/shell/10-setup.sh")"
  done
}

function update() {
  for dotfiles_path in "${dotfiles_paths[@]}"; do
    if test "$(git -C "${dotfiles_path}" branch --show-current)" != "main"; then
      echo "Not on main branch; exiting"
      exit 2
    fi
  done
  needs_updating=0
  for dotfiles_path in "${dotfiles_paths[@]}"; do
    git -C "${dotfiles_path}" fetch
    if test "$(git -C "${dotfiles_path}" rev-list --left-right --count main...origin/main | awk '{ print $1 }')" != "0"; then
      needs_updating=1
      exit 1
    fi
  done
  if [[ $needs_updating = 0 ]]; then
    echo "Already up to date; exiting"
    exit 1
  fi
  for dotfiles_path in "${dotfiles_paths[@]}"; do
    git -C "${dotfiles_path}" merge --ff-only
  done
}

case "${1:-}" in
  "")
    link_config
    check_all
    ;;
  
  update)
    update
    link_config
    check_all
    ;;

  *)
    if ! check "$1" > /dev/null; then
      read -p "Set up $(describe "$1")? " -n 1 -r
      echo
      if [[ $REPLY =~ ^[Yy]$ ]]; then
        fix "$1"
        check_all
      fi
    fi
    ;;
esac
