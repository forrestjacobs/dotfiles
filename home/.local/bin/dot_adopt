#!/usr/bin/env bash
set -e

if ! [ -f "$1" ]; then
  echo "'$1' is not a regular file"
  exit 1
fi

file="$(realpath "$1")"
if [[ $file != "${HOME}/"* ]]; then
  echo "'$1' is not in your home directory"
  exit 2
fi

IFS=':' read -ra dotfiles_paths <<< "$(dot_path)"
if [[ ${#dotfiles_paths[@]} = 1 ]]; then
  dotfiles_path=${dotfiles_paths[0]}
else
  echo "Where do you want to move this file?"
  select dotfiles_path in "${dotfiles_paths[@]}"; do
    if [[ $dotfiles_path != "" ]]; then
      break
    fi
  done
fi

if [[ $file == "${dotfiles_path}/"* ]]; then
  echo "'$1' is already in dotfiles"
  exit 3
fi
file="${file#"${HOME}"/}"

mkdir -p "${dotfiles_path}/home/$(dirname "$file")"
mv "${HOME}/${file}" "${dotfiles_path}/home/${file}"
ln -s "${dotfiles_path}/home/${file}" "${HOME}/${file}"
