#!/usr/bin/env bash
set -e

if ! [ -f "$1" ]; then
  echo "'$1' is not a regular file"
  exit 1
fi

file="$(realpath "$1")"
if [[ $file != "${HOME}/"* ]]; then
  echo "'$1' is not in your home directory"
  exit 2
fi

pushd "$(dirname "$(realpath "${BASH_SOURCE:0}")")" > /dev/null
dotfile_path="$(git rev-parse --show-toplevel)"
popd > /dev/null

if [[ $file == "${dotfile_path}/"* ]]; then
  echo "'$1' is already in dotfiles"
  exit 3
fi
file="${file#"${HOME}"/}"

mkdir -p "${dotfile_path}/home/$(dirname "$file")"
mv "${HOME}/${file}" "${dotfile_path}/home/${file}"
ln -s "${dotfile_path}/home/${file}" "${HOME}/${file}"
