cursor-style-blink = false
font-family = JetBrainsMonoNL Nerd Font Mono
font-size = 13.5
font-thicken = true
keybind = global:cmd+backquote=toggle_quick_terminal
shell-integration-features = cursor,sudo,title,ssh-env,no-ssh-terminfo,path
theme = Gruvbox Dark Hard
window-padding-x = 6
window-padding-y = 2
